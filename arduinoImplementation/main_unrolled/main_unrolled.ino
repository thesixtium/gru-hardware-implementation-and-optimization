// =============================================================================
// gru_unrolled.c
// GRU single-timestep inference, FULLY LOOP-UNROLLED
//
// Purpose: compile with avr-gcc -O2 -S to read the raw AVR assembly and see
// exactly which instructions execute one GRU timestep.
//
// Architecture: GRU cell, input size D=64, hidden size H=16
// Fixed-point:  Q10.6 (signed 16-bit, 6 fractional bits)
//
// GRU equations:
//   r[i] = sigmoid( W_ir[i][*]@x + b_ir[i] + W_hr[i][*]@h + b_hr[i] )
//   z[i] = sigmoid( W_iz[i][*]@x + b_iz[i] + W_hz[i][*]@h + b_hz[i] )
//   n[i] = tanh   ( W_in[i][*]@x + b_in[i] + r[i]*(W_hn[i][*]@h + b_hn[i]) )
//   h[i] = (1-z[i])*n[i] + z[i]*h_prev[i]
//
// Compile to assembly:
//   avr-gcc -mmcu=atmega2560 -O2 -S -o gru_unrolled.s gru_unrolled.c
// =============================================================================

#include <stdint.h>

// ---------------------------------------------------------------------------
// Fixed-point config  Q10.6
// ---------------------------------------------------------------------------
#define FRAC_BITS  6
#define FP_ONE     ((int16_t)64)
#define FP_MAX     ((int16_t)0x7FFF)
#define FP_MIN     ((int16_t)((int16_t)0x8000))

// ---------------------------------------------------------------------------
// Fixed-point primitives  (kept as inline functions so avr-gcc inlines them
// and the assembly is one flat sequence of instructions)
// ---------------------------------------------------------------------------
static inline int16_t fp_mul(int16_t a, int16_t b) {
    return (int16_t)(((int32_t)a * (int32_t)b) >> FRAC_BITS);
}

static inline int16_t fp_sat32(int32_t v) {
    if (v > FP_MAX) return FP_MAX;
    if (v < FP_MIN) return FP_MIN;
    return (int16_t)v;
}

static inline int16_t fp_add_sat(int16_t a, int16_t b) {
    int32_t s = (int32_t)a + (int32_t)b;
    if (s > FP_MAX) return FP_MAX;
    if (s < FP_MIN) return FP_MIN;
    return (int16_t)s;
}

static inline int16_t fp_sigmoid(int16_t x) {
    if (x <= (int16_t)(-320)) return (int16_t)0;
    if (x <= (int16_t)(-152)) return fp_add_sat((int16_t)10,  fp_mul((int16_t)2,  x));
    if (x <= (int16_t)( -64)) return fp_add_sat((int16_t)24,  fp_mul((int16_t)8,  x));
    if (x <= (int16_t)(  64)) return fp_add_sat((int16_t)32,  fp_mul((int16_t)16, x));
    if (x <= (int16_t)( 152)) return fp_add_sat((int16_t)40,  fp_mul((int16_t)8,  x));
    if (x <= (int16_t)( 320)) return fp_add_sat((int16_t)54,  fp_mul((int16_t)2,  x));
    return (int16_t)64;
}

static inline int16_t fp_tanh(int16_t x) {
    int32_t two_x_32 = (int32_t)x << 1;
    int16_t two_x = (two_x_32 > FP_MAX) ? FP_MAX :
                    (two_x_32 < FP_MIN) ? FP_MIN :
                    (int16_t)two_x_32;
    int16_t sig = fp_sigmoid(two_x);
    int32_t result = ((int32_t)sig << 1) - FP_ONE;
    return fp_sat32(result);
}

